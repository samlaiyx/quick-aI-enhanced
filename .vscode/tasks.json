// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "webpack: watch",
			"command": "pnpm",
			"args": ["run", "watch"],
			"problemMatcher": "$ts-webpack-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "webpack: build",
			"command": "pnpm",
			"args": ["run", "compile"],
			"problemMatcher": "$ts-webpack",
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build"
			}
		},
		{
			"type": "shell",
			"label": "tsc: watch-tests",
			"command": "pnpm",
			"args": ["run", "watch-tests"],
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build"
		},
		{
			"label": "tasks: watch-tests",
			"dependsOn": [
				"webpack: watch",
				"tsc: watch-tests"
			],
			"problemMatcher": []
		}
	]
}
